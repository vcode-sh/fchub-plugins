{
  "name": "fluentcart-mcp",
  "version": "1.0.2",
  "description": "MCP server for the FluentCart REST API — AI-agent-friendly tools for managing orders, products, customers, subscriptions, and more.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "fluentcart-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "pack:mcpb": "npm run build && npm prune --production && mcpb pack . fluentcart-mcp.mcpb"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fluentcart",
    "wordpress",
    "ecommerce",
    "ai",
    "agent",
    "orders",
    "products",
    "subscriptions"
  ],
  "author": "Vibe Code <hello@vcode.sh>",
  "license": "MIT",
  "homepage": "https://github.com/vcode-sh/fchub-plugins/tree/main/fluentcart-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vcode-sh/fchub-plugins.git",
    "directory": "fluentcart-mcp"
  },
  "bugs": {
    "url": "https://github.com/vcode-sh/fchub-plugins/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
