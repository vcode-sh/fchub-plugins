{
    "name": "vcode-sh/fchub-fakturownia",
    "description": "Fakturownia + KSeF 2.0 invoice integration for FluentCart",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "FChubFakturownia\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FChubFakturownia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
