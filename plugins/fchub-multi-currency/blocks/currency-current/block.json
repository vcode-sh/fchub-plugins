{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "fchub-multi-currency/current-currency",
  "version": "1.2.1",
  "title": "Current Currency",
  "category": "widgets",
  "icon": "money",
  "description": "Display the visitor's current display currency in compact form.",
  "keywords": ["currency", "current", "display", "money"],
  "textdomain": "fchub-multi-currency",
  "attributes": {
    "displayMode": {
      "type": "string",
      "default": "flag_code"
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true
    }
  },
  "style": "fchub-mc-switcher"
}
