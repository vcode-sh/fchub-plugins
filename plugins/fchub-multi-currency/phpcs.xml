<?xml version="1.0"?>
<ruleset name="FCHub Multi-Currency Coding Standards">
    <description>PSR-12 base with WordPress security checks</description>
    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/docs/*</exclude-pattern>
    <exclude-pattern>*/assets/*</exclude-pattern>
    <arg value="sp"/>
    <arg name="basepath" value="./"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>

    <rule ref="PSR12">
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
    </rule>
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="160"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
    <config name="testVersion" value="8.3-"/>
    <rule ref="PHPCompatibilityWP">
        <!-- False positive: PHPCompatibility doesn't understand PHP 8.1 enum methods -->
        <exclude name="PHPCompatibility.Variables.ForbiddenThisUseContexts.OutsideObjectContext"/>
    </rule>
    <rule ref="WordPress.DB.PreparedSQL">
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
    </rule>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>
    <rule ref="WordPress.Security.EscapeOutput"/>
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>
    <rule ref="WordPress.Security.NonceVerification"/>
    <config name="minimum_supported_wp_version" value="6.7"/>
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="fchub-multi-currency"/>
            </property>
        </properties>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions"/>
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions"/>
    <rule ref="WordPress.PHP.DevelopmentFunctions"/>
    <rule ref="WordPress.PHP.StrictInArray"/>
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="fchub_mc"/>
                <element value="fchubmc"/>
                <element value="FChubMultiCurrency"/>
                <element value="FCHUB_MC"/>
            </property>
        </properties>
    </rule>
</ruleset>
