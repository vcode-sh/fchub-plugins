<?xml version="1.0"?>
<ruleset name="FCHub Stream WordPress Coding Standards">
	<description>WordPress Coding Standards for FCHub Stream Plugin</description>

	<!-- What to scan -->
	<file>.</file>

	<!-- Exclude paths -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/admin-app/*</exclude-pattern>
	<exclude-pattern>*/portal-app/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/admin/dist/*</exclude-pattern>
	<exclude-pattern>*/todo/*</exclude-pattern>
	<exclude-pattern>*/knowledgebase/*</exclude-pattern>
	<exclude-pattern>*/docs/*</exclude-pattern>
	<exclude-pattern>test-*.php</exclude-pattern>

	<!-- How to scan -->
	<!-- Usage instructions: https://github.com/squizlabs/PHP_CodeSniffer/wiki/Usage -->
	<!-- Annotated ruleset: https://github.com/squizlabs/PHP_CodeSniffer/wiki/Annotated-ruleset.xml -->
	<arg value="sp"/> <!-- Show sniff and progress -->
	<arg name="basepath" value="./"/><!-- Strip the file paths down to the relevant bit -->
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/><!-- Enables parallel processing when available for faster results. -->

	<!-- Rules: Check PHP version compatibility -->
	<config name="testVersion" value="8.3-"/>
	<!-- https://github.com/PHPCompatibility/PHPCompatibilityWP -->
	<rule ref="PHPCompatibilityWP"/>

	<!-- Rules: WordPress Coding Standards -->
	<!-- https://github.com/WordPress-Coding-Standards/WordPress-Coding-Standards -->
	<config name="minimum_supported_wp_version" value="6.7"/>
	<rule ref="WordPress">
		<!-- Allow yoda conditions to be optional -->
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
		<!-- Allow multiple statements on same line for simple cases -->
		<exclude name="Generic.Formatting.DisallowMultipleStatements.SameLine"/>
		<!-- Allow unused parameters in interfaces/abstract methods -->
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.Found"/>
		<!-- Allow PSR-4 file naming (PascalCase.php) -->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<!-- Allow empty catch blocks (intentionally empty for error suppression) -->
		<exclude name="Generic.CodeAnalysis.EmptyStatement.DetectedCatch"/>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<!-- Value: replace the function, class, and variable prefixes used. -->
			<property name="prefixes" type="array">
				<element value="fchub_stream"/>
				<element value="fchubstream"/>
				<element value="FCHubStream"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<!-- Value: replace the text domain used. -->
			<property name="text_domain" type="array">
				<element value="fchub-stream"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WhiteSpace.ControlStructureSpacing">
		<properties>
			<property name="blank_line_check" value="true"/>
		</properties>
	</rule>
</ruleset>

