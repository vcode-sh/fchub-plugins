{
    "name": "fchub/memberships",
    "description": "FCHub Memberships - Complete membership system for FluentCart",
    "type": "wordpress-plugin",
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "FChubMemberships\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FChubMemberships\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
