{
    "name": "fchub/memberships",
    "description": "FCHub Memberships plugin development tooling",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "require": {},
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "FChubMemberships\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FChubMemberships\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    }
}
