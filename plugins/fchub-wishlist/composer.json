{
    "name": "fchub/wishlist",
    "description": "FCHub Wishlist - Wishlist system for FluentCart",
    "type": "wordpress-plugin",
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "FChubWishlist\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FChubWishlist\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
