{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "includes": ["resources/**/*.js", "resources/**/*.css"],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none",
      "arrowParentheses": "always"
    },
    "globals": [
      "window",
      "document",
      "fetch",
      "Promise",
      "Map",
      "Set",
      "setTimeout",
      "clearTimeout",
      "setInterval",
      "clearInterval",
      "URLSearchParams",
      "requestAnimationFrame",
      "location",
      "cartshift"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off",
        "useArrowFunction": "off",
        "useOptionalChain": "off",
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 30 }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn",
        "noInnerDeclarations": "off"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noDelete": "off",
        "useTopLevelRegex": "off"
      },
      "style": {
        "useConst": "warn",
        "useTemplate": "off",
        "noParameterAssign": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "noRedundantUseStrict": "off"
      }
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  }
}
